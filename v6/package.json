{
  "name": "notebound",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build:frontend": "bun build app/src/main.jsx --outfile app/bundle.js --minify",
    "watch:frontend": "bun build --watch app/src/main.jsx --outfile app/bundle.js --sourcemap=inline",
    "start": "bun run build:frontend && electron .",
    "dev": "bun run build:frontend && electron .",
    "dist": "bun run build:frontend && electron-builder"
  },
  "dependencies": {
    "preact": "^10.25.0",
    "@preact/signals": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.notebound",
    "productName": "Notebound",
    "icon": "icon.png",
    "files": [
      "main.js",
      "src/**/*",
      "app/**/*",
      "!app/src/**/*",
      "icon.png"
    ],
    "directories": {
      "output": "out"
    }
  }
}
